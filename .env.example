# KnowNet local development defaults

APP_ENV=local
PUBLIC_MODE=false

# Set this before exposing the API beyond localhost.
# ADMIN_TOKEN=replace-with-a-long-random-token
ADMIN_TOKEN_MIN_CHARS=32
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900

# Optional external access guard. Use this with Cloudflare Access when PUBLIC_MODE=true.
CLOUDFLARE_ACCESS_REQUIRED=false
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=
CLOUDFLARE_ACCESS_REQUIRE_JWT=true

DATA_DIR=./data
SQLITE_PATH=./data/knownet.db
KNOWNET_DB_VERSION=v2
RUST_CORE_PATH=./.local/cargo-target/debug/knownet-core.exe

# Keep first startup fast. Set true when you want local semantic embeddings.
LOCAL_EMBEDDING_AUTO_LOAD=false
LOCAL_EMBEDDING_LOCAL_FILES_ONLY=true
LOCAL_EMBEDDING_MODEL=snunlp/KR-SBERT-V40K-klueNLI-augSTS

# Optional OpenAI draft service. If unset, KnowNet uses its local mock draft path.
# Uses the Responses API with Structured Outputs.
# OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=2000
OPENAI_TIMEOUT_SECONDS=60

# Optional server-side model reviewers. Keep real keys in local .env only.
# GEMINI_API_KEY=
GEMINI_RUNNER_ENABLED=false
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESPONSE_MIME_TYPE=application/json
GEMINI_THINKING_BUDGET=0
GEMINI_TIMEOUT_SECONDS=90

# DEEPSEEK_API_KEY=
DEEPSEEK_RUNNER_ENABLED=false
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true

# MINIMAX_API_KEY=
MINIMAX_RUNNER_ENABLED=false
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_MAX_TOKENS=4000
MINIMAX_REASONING_SPLIT=true
MINIMAX_TIMEOUT_SECONDS=90

# Qwen uses Alibaba Cloud DashScope OpenAI-compatible mode.
# QWEN_API_KEY can also be supplied from an existing DASHSCOPE_API_KEY value.
# QWEN_API_KEY=
QWEN_RUNNER_ENABLED=false
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_MAX_TOKENS=4000
QWEN_ENABLE_SEARCH=false
QWEN_TIMEOUT_SECONDS=90

# Kimi / Moonshot uses OpenAI-compatible chat completions.
# K2.5 docs use max_tokens and explicit thinking control.
# KIMI_API_KEY=
KIMI_RUNNER_ENABLED=false
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5
KIMI_MAX_TOKENS=4000
KIMI_THINKING_ENABLED=false
KIMI_TIMEOUT_SECONDS=90

# GLM_API_KEY=
GLM_RUNNER_ENABLED=false
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.1
GLM_MAX_TOKENS=4000
GLM_THINKING_ENABLED=false
GLM_TIMEOUT_SECONDS=90

BACKUP_RETENTION_COUNT=10
BACKUP_MAX_BYTES=1073741824
RESTORE_REQUIRE_SNAPSHOT=true
HEALTH_BACKUP_MAX_AGE_HOURS=168

# Empty means the browser calls the same origin and Next.js proxies /api to the local API.
NEXT_PUBLIC_API_BASE=
KNOWNET_API_INTERNAL=http://127.0.0.1:8000
