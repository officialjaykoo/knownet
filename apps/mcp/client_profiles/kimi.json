{
  "id": "kimi",
  "display_name": "Kimi / Moonshot",
  "github_references": [
    "https://github.com/MoonshotAI/kimi-cli"
  ],
  "best_paid_path": "Kimi API runner for reviews, or Kimi Code CLI with KnowNet MCP over stdio or HTTP.",
  "realistic_free_path": "Kimi web chat GET preview; Kimi CLI if installed.",
  "implemented_surface": "POST /api/model-runs/kimi/reviews and apps/mcp/configs/kimi_mcp.example.json",
  "test_status": "api_runner_mock_ready_mcp_config_template_ready_unverified",
  "requires_paid_or_external_setup": true,
  "access_strategy": "split_free_pack_paid_runner",
  "path_policy": "Free web uses generated review pack; paid/API access is required for Kimi API key and live runner.",
  "keep_separate_free_paid_paths": true,
  "primary_path": "api_runner_when_paid_key_available",
  "connection_modes": [
    {
      "mode": "provider_runner",
      "endpoint": "POST /api/model-runs/kimi/reviews",
      "provider_family": "openai_compatible_tool_calling"
    },
    {
      "mode": "kimi_mcp_config_file",
      "config_template": "apps/mcp/configs/kimi_mcp.example.json"
    },
    {
      "mode": "kimi_cli_add_http",
      "command": "kimi mcp add --transport http knownet https://REPLACE_WITH_PROTECTED_DOMAIN/mcp"
    }
  ],
  "do_not_add": [
    "Kimi web chat MCP assumptions",
    "kimi_* MCP tools"
  ]
}
