      "mode": "local_stdio",
      "settings_file": "~/.gemini/settings.json or .gemini/settings.json",
      "trust": false,
      "config_template": "apps/mcp/configs/gemini_cli_settings.example.json"
    },
    {
      "mode": "streamable_http_bridge",
      "url": "https://REPLACE_WITH_PROTECTED_DOMAIN/mcp",
      "trust": false
    }
  ],
  "do_not_add": [
    "Gemini web chat MCP assumptions",
    "Gemini-specific KnowNet MCP tools"
  ]
}
